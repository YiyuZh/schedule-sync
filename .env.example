APP_ENV=production
APP_NAME=schedule-sync-server
APP_BASE_URL=https://schedule-sync.zenithy.art
SCHEDULE_SYNC_DOMAIN=schedule-sync.zenithy.art

POSTGRES_DB=schedule_sync
POSTGRES_USER=autsky
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+psycopg://autsky:replace-with-strong-password@postgres:5432/schedule_sync
RUN_MIGRATIONS_ON_START=true

JWT_SECRET=replace-with-generated-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_EMAIL=autsky6666@gmail.com
ADMIN_PASSWORD_HASH=replace-with-admin-password-hash
ADMIN_TOKEN_EXPIRE_MINUTES=30
# ADMIN_PASSWORD=only-for-local-development

SCHEDULE_SYNC_PREVIEW_PORT=18130
SHARED_CADDY_NETWORK=shared_gateway
UVICORN_WORKERS=1

ALLOWED_ORIGINS=http://127.0.0.1:1420,http://localhost:1420,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174,http://localhost,tauri://localhost,capacitor://localhost,ionic://localhost,https://schedule-sync.zenithy.art

MOBILE_LATEST_VERSION=0.1.0
MOBILE_MIN_SUPPORTED_VERSION=0.1.0
MOBILE_UPDATE_REQUIRED=false
MOBILE_RELEASE_NOTES=日程安排手机端持续优化中。
MOBILE_TESTFLIGHT_URL=
MOBILE_APP_STORE_URL=

PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
APT_SECURITY_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian-security
